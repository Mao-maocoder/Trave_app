NEXT_PUBLIC_AMAP_SECURITY_KEY=your_amap_security_key_here
# ---- OpenAI ----
OPENAI_API_KEY=

# ---- DeepL ----
DEEPL_API_KEY=

# ---- 和风天气 ----
QWEATHER_KEY=

# ---- Cloudinary ----
